<?xml version="1.0" encoding="utf-8"?>
<robot name="m2_metal">
    <mujoco>
        <compiler 
        meshdir="../meshes"
        discardvisual="false"
    />
    </mujoco>
<!--
    <link name="world"/>
    <joint name="floating_base" type="floating">
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <parent link="world"/>
      <child link="base"/>
    </joint>
-->
    <material name="black">
    <color rgba="0.0 0.0 0.0 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.156 0.55 0.96 1.0"/>
  </material>
  <material name="green">
    <color rgba="0.024 0.251 0.169 1.0"/>
  </material>
  <material name="gray">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>
  <!-- Base link -->
  <link name="base">
    <inertial>
      <!-- <origin xyz="0.058346 -0.002972 0.001919" rpy="0 0 0"/> -->
      <!-- <mass value="5.18596663"/>
