      <origin xyz="-0.05 -0.01 0.12" rpy="0 0 0"/>
      <mass value="9.18596663"/>
      <inertia ixx="0.1844" ixy="-0.00040" ixz="-0.00096" iyy="0.254" iyz="-2.54e-05" izz="0.128"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://m2_metal_description/meshes/torso.STL"/>
      </geometry>
      <material name="gray"/>
    </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.28 0.20 0.114"/>
        </geometry>
      </collision>
  </link>

  <!-- IMU link -->
  <link name="imu_link"/>
  <joint name="base_to_imu" type="fixed">
    <parent link="base"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <joint name="FL_hip_joint" type="revolute">
